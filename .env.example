# ========================================
# 環境変数サンプル
# ========================================

# アプリケーション環境（development / production）
APP_ENV=development

# ローカル Postgres コンテナ
DATABASE_URL=postgresql://postgres:postgres@db:5432/jantama
PGSSLMODE=disable

# Neon dev ブランチを使う場合
# DATABASE_URL=
# PGSSLMODE=require

# Cloudflare Turnstile（bot対策）
# 開発用テストキー（常に成功）:
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Discord Bot
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_GUILD_ID=

# Discord OAuth2（選手の Discord 連携）
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8080/discord_oauth_callback

# OAuth state 署名鍵（`openssl rand -hex 32` で生成）
APP_SECRET=
