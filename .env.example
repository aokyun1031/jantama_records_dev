# ========================================
# 環境変数サンプル
# ========================================

# アプリケーション環境（development / production）
# ※ 本番（production）はRender管理画面で設定
APP_ENV=development

# ローカル Postgres コンテナ（docker-compose.yml の db サービス）
DATABASE_URL=postgresql://postgres:postgres@db:5432/jantama
PGSSLMODE=disable

# Neon dev ブランチを使う場合
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# PGSSLMODE=require

# Cloudflare Turnstile（bot対策）
# 開発用テストキー（常に成功）:
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
