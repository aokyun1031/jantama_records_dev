# ========================================
# 環境変数サンプル
# ========================================

# --- ローカル開発（docker）---
# PGHOST=db
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=your_database
# PGPORT=5432
# PGSSLMODE=disable

# --- ローカル開発（Neon）---
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# PGSSLMODE=require

# --- 本番（Render管理画面で設定）---
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# PGSSLMODE=require
